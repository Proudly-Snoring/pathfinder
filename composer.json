{
  "name": "exodus4d/pathfinder",
  "description": "Mapping tool for EVE ONLINE",
  "type": "project",
  "homepage": "https://github.com/exodus4d/pathfinder",
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Mark Friedrich",
      "email": "pathfinder@exodus4d.de"
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "lock": true,
    "platform": {
      "php": "7.2.34",
      "ext-pdo": "7.2.34",
      "ext-openssl": "7.2.34",
      "ext-curl": "7.2.34",
      "ext-json": "7.2.34",
      "ext-mbstring": "7.2.34",
      "ext-ctype": "7.2.34",
      "ext-gd": "7.2.34"
    }
  },
  "autoload": {
    "psr-4": {
      "Exodus4D\\Pathfinder\\": "app/"
    }
  },
  "readme": "README.md",
  "require": {
    "php-64bit": ">=7.2",
    "ext-pdo": "*",
    "ext-openssl": "*",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-ctype": "*",
    "ext-gd": "*",
    "bcosca/fatfree-core": "3.9.*",
    "ikkez/f3-cortex": "^1.7",
    "ikkez/f3-sheet": "0.4.*",
    "xfra35/f3-cron": "1.3.*",
    "monolog/monolog": "2.3.5",
    "league/html-to-markdown": "5.1.*",
    "cache/redis-adapter": "1.1.*",
    "cache/filesystem-adapter": "1.1.*",
    "cache/array-adapter": "1.1.*",
    "cache/namespaced-cache": "1.1.*",
    "react/socket": "1.17.*",
    "react/promise": "^3",
    "react/promise-stream": "1.7.*",
    "clue/ndjson-react": "1.3.*",
    "firebase/php-jwt": "6.*",
    "goryn-clade/pathfinder_esi": "2.1.4"
  },
  "suggest": {
    "ext-redis": "Redis can be used as cache backend."
  }
}
