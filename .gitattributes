# Normalize line endings: keep LF in the repo for source/text files
* text=auto eol=lf

# ==============================================================================
# Assets that are normalized
# ==============================================================================

*.css text
*.html text
*.ini text
*.js text
*.json text
*.md text
*.txt text
*.xml text

# ==============================================================================
# Assets that must NEVER be normalized
# ==============================================================================

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary

# Archives
*.gz binary
*.tar binary
*.zip binary
