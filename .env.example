# Web -------------------------------------------------------------------
# Host name the app is reached under (used for nginx server_name + the app URL that SSO callbacks/absolute links are built from).
# MUST include the port when it is not 80, e.g. localhost:8080 — keep it in sync with HTTP_PORT below.
DOMAIN=localhost:8080
# Host port mapped to the container's nginx (http://localhost:8080).
HTTP_PORT=8080
# Basic-auth password protecting the /setup route (user: pf).
APP_PASSWORD=CHANGE_ME

# Timezone --------------------------------------------------------------
TZ=UTC

# Database --------------------------------------------------------------
MYSQL_HOST=pfdb
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_USER=pathfinder
MYSQL_PASSWORD=CHANGE_ME
MYSQL_PF_DB_NAME=pathfinder
MYSQL_UNIVERSE_DB_NAME=eve_universe
MYSQL_CCP_DB_NAME=eve_ccp

# Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# Websocket -------------------------------------------------------------
PATHFINDER_SOCKET_HOST=socket
PATHFINDER_SOCKET_PORT=5555

# EVE Online SSO / ESI --------------------------------------------------
CCP_SSO_CLIENT_ID=
CCP_SSO_SECRET_KEY=
CCP_ESI_SCOPES=esi-location.read_location.v1,esi-location.read_ship_type.v1,esi-search.search_structures.v1,esi-clones.read_clones.v1,esi-universe.read_structures.v1,esi-corporations.read_corporation_membership.v1,esi-ui.open_window.v1,esi-ui.write_waypoint.v1,esi-characters.read_corporation_roles.v1,esi-location.read_online.v1

# SMTP (optional) -------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_SCHEME=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_EMAIL=
